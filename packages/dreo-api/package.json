{
    "name": "@dreo/api",
    "version": "0.1.0",
    "private": true,
    "description": "Unofficial TypeScript SDK for accessing DREO cloud-connected devices.",
    "license": "MIT",
    "author": "mehrwiedu",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "dreo",
        "typescript",
        "sdk",
        "api",
        "smart-home",
        "iot",
        "fan",
        "humidifier"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/ws": "^8.18.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mehrwiedu/dreo-cloud.git",
        "directory": "packages/dreo-api"
    },
    "homepage": "https://github.com/mehrwiedu/dreo-cloud#readme",
    "bugs": {
        "url": "https://github.com/mehrwiedu/dreo-cloud/issues"
    }
}
